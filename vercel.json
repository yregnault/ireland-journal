{
  "functions": {
    "api/storage.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/summary.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}